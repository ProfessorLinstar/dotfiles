{
  "permissions": {
    "allow": [
      "Bash(rm /tmp/claude-ci-state/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/post-push-ci.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/stop-ci-check.sh"
          }
        ]
      }
    ]
  }
}
